# ClawTeam Graph Configuration
swarm_name: nudge-thing-centric-graph

# Trigger Layer
trigger:
  type: io-loop
  monitor_dir: ./backlog/tasks
  event_filter: "status: To Do"

# Task Session (The "Thing")
session_defaults:
  state_dir: ./alt/state
  task_board: ./backlog
  # gateway_url: optional, only when mixing real-API models via LiteLLM etc.
  # For pure subscription CLIs: omit. Use per-agent monitor status + usage probes for quotas.

# Graph Nodes (Roles within the Session Graph)
node_profiles:
  - role: planner
    model: claude-3-opus
    persistence_mode: session-locked
    capabilities: ["task-decomposition", "graph-orchestration"]

  - role: implementer
    model: claude-3-haiku
    persistence_mode: session-locked
    capabilities: ["code-writing", "test-generation"]

  - role: reviewer
    model: gpt-4o-mini
    persistence_mode: event-driven
    capabilities: ["security-audit", "convention-check"]

# Spawning Logic
graph_rules:
  - trigger: sub-task-detected
    action: spawn-node
    role-mapping:
      - type: "feature" -> role: "implementer"
      - type: "bug" -> role: "implementer"
      - type: "review" -> role: "reviewer"

# Persistence & Resumption
resumption:
  use_session_id: true
  reprime_mode: full-transcript
