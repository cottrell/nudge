# LiteLLM Configuration (Alternative to Bifrost)
model_list:
  - model_name: gpt-4
    litellm_params:
      model: openai/gpt-4
      api_key: "os.environ/OPENAI_API_KEY"
  - model_name: claude-3
    litellm_params:
      model: anthropic/claude-3-opus-20240229
      api_key: "os.environ/ANTHROPIC_API_KEY"

router_settings:
  routing_strategy: simple-shuffle
  set_verbose: True

general_settings:
  master_key: "sk-1234"
